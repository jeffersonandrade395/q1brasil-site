# Servidor-only — NUNCA usar prefixo NEXT_PUBLIC_ nestas variáveis.
# Configurar na Vercel (Production) e em .env.local para dev.

# Supabase (projeto separado — somente leads_piloto; RLS sem policy, insert via service_role)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Resend (domínio q1brasil.com.br Verified; from precisa ser @q1brasil.com.br)
RESEND_API_KEY=
LEAD_NOTIFY_TO=
# Opcional — default: "Q1 Brasil <piloto@q1brasil.com.br>"
RESEND_FROM=
